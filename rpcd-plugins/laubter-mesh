#!/bin/sh
# laubter-mesh: Generic mesh WiFi integration proxy for Laubter
# Currently implements ASUS AiMesh provider
# Credentials: username in UCI, password in a chmod 600 file

. /usr/share/libubox/jshn.sh

DATA_DIR="/tmp/laubter/mesh"
PASS_FILE="/etc/laubter_mesh_secret"
CACHE_TTL=5

mkdir -p "$DATA_DIR"

get_config() {
	MESH_PROVIDER=$(uci -q get laubter.mesh.provider 2>/dev/null || echo "openwrt")
	MESH_HOST=$(uci -q get laubter.mesh.host 2>/dev/null || echo "192.168.50.2")
	MESH_PORT=$(uci -q get laubter.mesh.port 2>/dev/null || echo "8443")
	MESH_PROTO=$(uci -q get laubter.mesh.proto 2>/dev/null || echo "https")
	MESH_USER=$(uci -q get laubter.mesh.username 2>/dev/null || echo "admin")
	MESH_PASS=""
	[ -f "$PASS_FILE" ] && MESH_PASS=$(cat "$PASS_FILE" 2>/dev/null)
	MESH_URL="${MESH_PROTO}://${MESH_HOST}:${MESH_PORT}"
}

asus_login() {
	get_config
	[ -z "$MESH_PASS" ] && return 1

	AUTH_B64=$(printf '%s:%s' "$MESH_USER" "$MESH_PASS" | base64 | tr -d '\n')

	# Use ASUS app API (User-Agent trick) — works alongside browser sessions
	RESP=$(curl -sk -X POST "${MESH_URL}/login.cgi" \
		-H "user-agent: asusrouter-Android-DUTUtil-1.0.0.245" \
		-d "login_authorization=${AUTH_B64}" 2>/dev/null)

	# App API returns JSON with asus_token
	TOKEN=$(echo "$RESP" | grep -o '"asus_token":"[^"]*"' | cut -d'"' -f4)

	if [ -n "$TOKEN" ]; then
		echo "$TOKEN" > "$DATA_DIR/.token"
		date +%s > "$DATA_DIR/.auth_time"
		return 0
	fi

	return 1
}

asus_ensure_auth() {
	NOW=$(date +%s)

	# Cooldown: don't attempt login if we applied settings recently (ASUS restarts httpd)
	if [ -f "$DATA_DIR/.cooldown" ]; then
		COOL_TIME=$(cat "$DATA_DIR/.cooldown" 2>/dev/null || echo 0)
		COOL_AGE=$((NOW - COOL_TIME))
		[ "$COOL_AGE" -lt 15 ] && return 1
		rm -f "$DATA_DIR/.cooldown"
	fi

	# Rate limit: no more than 1 login attempt per 30 seconds
	if [ -f "$DATA_DIR/.last_login_attempt" ]; then
		LAST=$(cat "$DATA_DIR/.last_login_attempt" 2>/dev/null || echo 0)
		SINCE=$((NOW - LAST))
		[ "$SINCE" -lt 30 ] && [ -f "$DATA_DIR/.token" ] && return 0
		[ "$SINCE" -lt 30 ] && return 1
	fi

	if [ -f "$DATA_DIR/.auth_time" ]; then
		AUTH_TIME=$(cat "$DATA_DIR/.auth_time" 2>/dev/null || echo 0)
		AGE=$((NOW - AUTH_TIME))
		[ "$AGE" -lt 1200 ] && return 0
	fi
	date +%s > "$DATA_DIR/.last_login_attempt"
	asus_login
}

asus_fetch() {
	local hook="$1"
	local cache_key=$(printf '%s' "$hook" | md5sum | cut -c1-12)
	local cache_file="$DATA_DIR/cache_${cache_key}.json"

	if [ -f "$cache_file" ]; then
		NOW=$(date +%s)
		FILE_TIME=$(date -r "$cache_file" +%s 2>/dev/null || echo 0)
		AGE=$((NOW - FILE_TIME))
		[ "$AGE" -lt "$CACHE_TTL" ] && cat "$cache_file" && return 0
	fi

	asus_ensure_auth || return 1

	get_config
	TOKEN=$(cat "$DATA_DIR/.token" 2>/dev/null)

	RESULT=$(curl -sk \
		-H "Cookie: asus_s_token=${TOKEN}" \
		-H "user-agent: asusrouter-Android-DUTUtil-1.0.0.245" \
		"${MESH_URL}/appGet.cgi?hook=${hook}" 2>/dev/null)

	if echo "$RESULT" | grep -q "Main_Login"; then
		asus_login || return 1
		TOKEN=$(cat "$DATA_DIR/.token" 2>/dev/null)
		RESULT=$(curl -sk \
			-H "Cookie: asus_s_token=${TOKEN}" \
			-H "user-agent: asusrouter-Android-DUTUtil-1.0.0.245" \
			"${MESH_URL}/appGet.cgi?hook=${hook}" 2>/dev/null)
	fi

	[ -n "$RESULT" ] && echo "$RESULT" > "$cache_file" && echo "$RESULT" || echo '{}'
}

asus_apply() {
	local post_data="$1"

	asus_ensure_auth || { echo '{"error":"Not authenticated"}'; return 1; }

	get_config
	TOKEN=$(cat "$DATA_DIR/.token" 2>/dev/null)

	RESULT=$(curl -sk -X POST \
		-H "Cookie: asus_s_token=${TOKEN}" \
		-H "user-agent: asusrouter-Android-DUTUtil-1.0.0.245" \
		"${MESH_URL}/applyapp.cgi" \
		-d "$post_data" 2>/dev/null)

	# Clear cache and set cooldown after any apply action
	rm -f "$DATA_DIR"/cache_*.json "$DATA_DIR/.auth_time"
	date +%s > "$DATA_DIR/.cooldown"

	# Check for auth failure
	if echo "$RESULT" | grep -q "Main_Login"; then
		echo '{"error":"Session expired, please retry"}'
		return 1
	fi

	echo "$RESULT"
}

case "$1" in
	list)
		cat <<-'EOF'
{
	"get_nodes": {},
	"get_clients": {},
	"get_topology": {},
	"get_wireless_clients": {},
	"get_wired_clients": {},
	"get_info": {},
	"bind_client": { "client_mac": "str", "target_mac": "str", "band": "str" },
	"configure": { "host": "str", "port": "str", "proto": "str", "username": "str", "password": "str", "provider": "str" },
	"get_config": {},
	"test_connection": {},
	"set_node_config": { "mac": "str", "led": "str", "backhaul_priority": "str", "preferred_uplink": "str" },
	"reboot_node": { "mac": "str" }
}
EOF
		;;
	call)
		case "$2" in
			get_nodes)
				RAW=$(asus_fetch "get_cfg_clientlist()")
				[ -z "$RAW" ] && echo '{"get_cfg_clientlist":[]}' || echo "$RAW"
				;;
			get_clients)
				RAW=$(asus_fetch "get_clientlist()")
				[ -z "$RAW" ] && echo '{"get_clientlist":{}}' || echo "$RAW"
				;;
			get_topology)
				RAW=$(asus_fetch "get_allclientlist()")
				[ -z "$RAW" ] && echo '{"get_allclientlist":{}}' || echo "$RAW"
				;;
			get_wireless_clients)
				asus_fetch "get_wclientlist()"
				;;
			get_wired_clients)
				asus_fetch "get_wiredclientlist()"
				;;
			get_info)
				asus_fetch "nvram_get(wl0_ssid)%3Bnvram_get(wl1_ssid)%3Bnvram_get(wl2_ssid)%3Bnvram_get(productid)%3Bnvram_get(firmver)%3Bnvram_get(buildno)%3Bnvram_get(lan_ipaddr)"
				;;
			configure)
				read -r input
				json_load "$input" 2>/dev/null

				json_get_var host host
				json_get_var port port
				json_get_var proto proto
				json_get_var username username
				json_get_var password password
				json_get_var provider provider

				uci -q get laubter.mesh >/dev/null 2>&1 || {
					touch /etc/config/laubter
					uci set laubter.mesh=mesh
				}

				[ -n "$host" ] && uci set laubter.mesh.host="$host"
				[ -n "$port" ] && uci set laubter.mesh.port="$port"
				[ -n "$proto" ] && uci set laubter.mesh.proto="$proto"
				[ -n "$username" ] && uci set laubter.mesh.username="$username"
				[ -n "$provider" ] && uci set laubter.mesh.provider="$provider"
				uci commit laubter

				# Store password in a separate file with restricted permissions
				if [ -n "$password" ]; then
					printf '%s' "$password" > "$PASS_FILE"
					chmod 600 "$PASS_FILE"
				fi

				# Clear cache
				rm -f "$DATA_DIR"/cache_*.json "$DATA_DIR/.auth_time"

				echo '{"status":"ok"}'
				;;
			get_config)
				get_config
				HAS_PASS=0
				[ -n "$MESH_PASS" ] && HAS_PASS=1
				json_init
				json_add_string "provider" "$MESH_PROVIDER"
				json_add_string "host" "$MESH_HOST"
				json_add_string "port" "$MESH_PORT"
				json_add_string "proto" "$MESH_PROTO"
				json_add_string "username" "$MESH_USER"
				json_add_boolean "has_password" "$HAS_PASS"
				json_dump
				;;
			bind_client)
				# Bind/unbind a client to a specific mesh node using sta_binding_list nvram
				# Format: <NODE_MAC>enable>CLIENT_MAC,band_index|CLIENT2,band2...
				read -r input
				json_load "$input" 2>/dev/null
				json_get_var client_mac client_mac
				json_get_var target_mac target_mac
				json_get_var band band
				[ -z "$band" ] && band="0"
				[ -z "$client_mac" ] && { echo '{"error":"client_mac required"}'; exit 0; }

				asus_ensure_auth || { echo '{"error":"Not authenticated"}'; exit 0; }
				get_config
				TOKEN=$(cat "$DATA_DIR/.token" 2>/dev/null)

				# Get current binding list
				CURRENT=$(curl -sk \
					-H "Cookie: asus_s_token=${TOKEN}" \
					-H "user-agent: asusrouter-Android-DUTUtil-1.0.0.245" \
					"${MESH_URL}/appGet.cgi?hook=nvram_get(sta_binding_list)" 2>/dev/null)

				# Parse current list (HTML-encoded: &#60 = <, &#62 = >, &#124 = |)
				BIND_LIST=$(echo "$CURRENT" | grep -o '"sta_binding_list":"[^"]*"' | cut -d'"' -f4 \
					| sed 's/&#60/</g; s/&#62/>/g; s/&#124/|/g; s/&#44/,/g')

				if [ -z "$target_mac" ]; then
					# Unbind: remove client from all nodes in the list
					NEW_LIST=""
					IFS='<'
					for entry in $BIND_LIST; do
						[ -z "$entry" ] && continue
						NODE=$(echo "$entry" | cut -d'>' -f1)
						ENABLE=$(echo "$entry" | cut -d'>' -f2)
						CLIENTS=$(echo "$entry" | cut -d'>' -f3)
						# Remove this client from the client list
						NEW_CLIENTS=""
						IFS='|'
						for cl in $CLIENTS; do
							CL_MAC=$(echo "$cl" | cut -d',' -f1)
							if [ "$(echo "$CL_MAC" | tr 'a-f' 'A-F')" != "$(echo "$client_mac" | tr 'a-f' 'A-F')" ]; then
								[ -n "$NEW_CLIENTS" ] && NEW_CLIENTS="${NEW_CLIENTS}|"
								NEW_CLIENTS="${NEW_CLIENTS}${cl}"
							fi
						done
						unset IFS
						# Keep node entry if it still has clients
						if [ -n "$NEW_CLIENTS" ]; then
							NEW_LIST="${NEW_LIST}<${NODE}>${ENABLE}>${NEW_CLIENTS}"
						fi
					done
					unset IFS
				else
					# Bind: first remove client from any existing node, then add to target
					# Remove client from existing entries
					CLEANED=""
					IFS='<'
					for entry in $BIND_LIST; do
						[ -z "$entry" ] && continue
						NODE=$(echo "$entry" | cut -d'>' -f1)
						ENABLE=$(echo "$entry" | cut -d'>' -f2)
						CLIENTS=$(echo "$entry" | cut -d'>' -f3)
						NEW_CLIENTS=""
						IFS='|'
						for cl in $CLIENTS; do
							CL_MAC=$(echo "$cl" | cut -d',' -f1)
							if [ "$(echo "$CL_MAC" | tr 'a-f' 'A-F')" != "$(echo "$client_mac" | tr 'a-f' 'A-F')" ]; then
								[ -n "$NEW_CLIENTS" ] && NEW_CLIENTS="${NEW_CLIENTS}|"
								NEW_CLIENTS="${NEW_CLIENTS}${cl}"
							fi
						done
						unset IFS
						if [ -n "$NEW_CLIENTS" ]; then
							CLEANED="${CLEANED}<${NODE}>${ENABLE}>${NEW_CLIENTS}"
						fi
					done
					unset IFS

					# Add client to target node
					TARGET_UP=$(echo "$target_mac" | tr 'a-f' 'A-F')
					CLIENT_UP=$(echo "$client_mac" | tr 'a-f' 'A-F')
					# Check if target node already exists in list
					if echo "$CLEANED" | grep -qi "<${TARGET_UP}>"; then
						# Append client to existing node entry
						NEW_LIST=$(echo "$CLEANED" | sed "s|<${TARGET_UP}>\([^>]*\)>\([^<]*\)|<${TARGET_UP}>\1>\2|${CLIENT_UP},${band}|")
						# Simpler: rebuild
						NEW_LIST=""
						FOUND=0
						IFS='<'
						for entry in $CLEANED; do
							[ -z "$entry" ] && continue
							NODE=$(echo "$entry" | cut -d'>' -f1)
							ENABLE=$(echo "$entry" | cut -d'>' -f2)
							CLIENTS=$(echo "$entry" | cut -d'>' -f3)
							if [ "$(echo "$NODE" | tr 'a-f' 'A-F')" = "$TARGET_UP" ]; then
								CLIENTS="${CLIENTS}|${CLIENT_UP},${band}"
								FOUND=1
							fi
							NEW_LIST="${NEW_LIST}<${NODE}>${ENABLE}>${CLIENTS}"
						done
						unset IFS
						if [ "$FOUND" = "0" ]; then
							NEW_LIST="${NEW_LIST}<${TARGET_UP}>1>${CLIENT_UP},${band}"
						fi
					else
						NEW_LIST="${CLEANED}<${TARGET_UP}>1>${CLIENT_UP},${band}"
					fi
				fi

				# Apply via start_apply.htm
				RESULT=$(curl -sk -X POST \
					-H "Cookie: asus_s_token=${TOKEN}" \
					-H "user-agent: asusrouter-Android-DUTUtil-1.0.0.245" \
					-H "Referer: ${MESH_URL}/AiMesh.asp" \
					"${MESH_URL}/start_apply.htm" \
					--data-urlencode "action_mode=apply" \
					--data-urlencode "rc_service=update_sta_binding" \
					--data-urlencode "sta_binding_list=${NEW_LIST}" 2>/dev/null)

				# Clear cache and set cooldown (ASUS restarts httpd after apply)
				rm -f "$DATA_DIR"/cache_*.json "$DATA_DIR/.auth_time"
				date +%s > "$DATA_DIR/.cooldown"

				# Auth failure returns a tiny redirect page (~88 bytes)
				# Success returns a full HTML page with done_committing()
				RESULT_LEN=$(printf '%s' "$RESULT" | wc -c)
				if [ "$RESULT_LEN" -lt 200 ] && echo "$RESULT" | grep -q "Main_Login"; then
					echo '{"error":"Session expired, please retry"}'
				else
					echo '{"status":"ok"}'
				fi
				;;

			set_node_config)
				read -r input
				json_load "$input" 2>/dev/null
				json_get_var mac mac
				json_get_var led led
				json_get_var backhaul_priority backhaul_priority
				json_get_var preferred_uplink preferred_uplink

				[ -z "$mac" ] && { echo '{"error":"mac required"}'; exit 0; }

				# LED control
				if [ -n "$led" ]; then
					RESULT=$(asus_apply "action_mode=config&re_mac=${mac}&config={\"ctrl_led\":{\"led_val\":\"${led}\"}}")
					if echo "$RESULT" | grep -q '"error"'; then
						echo "$RESULT"
						exit 0
					fi
				fi

				# Backhaul priority: auto=3, ethernet=1, wireless=2
				if [ -n "$backhaul_priority" ]; then
					case "$backhaul_priority" in
						ethernet) BH_VAL="1" ;;
						wireless) BH_VAL="2" ;;
						*) BH_VAL="3" ;;
					esac
					RESULT=$(asus_apply "action_mode=config&re_mac=${mac}&config={\"backhalctrl\":{\"amas_ethernet\":\"${BH_VAL}\"}}")
					if echo "$RESULT" | grep -q '"error"'; then
						echo "$RESULT"
						exit 0
					fi
				fi

				# Preferred uplink AP
				if [ -n "$preferred_uplink" ]; then
					RESULT=$(asus_apply "action_mode=config&re_mac=${mac}&config={\"prefer_ap\":{\"amas_wlc_target_bssid\":\"${preferred_uplink}\",\"amas_wlc0_target_bssid\":\"\",\"amas_wlc1_target_bssid\":\"\",\"amas_wlc2_target_bssid\":\"\"}}")
					if echo "$RESULT" | grep -q '"error"'; then
						echo "$RESULT"
						exit 0
					fi
				fi

				echo '{"status":"ok"}'
				;;

			reboot_node)
				read -r input
				json_load "$input" 2>/dev/null
				json_get_var mac mac
				[ -z "$mac" ] && { echo '{"error":"mac required"}'; exit 0; }

				RESULT=$(asus_apply "action_mode=reboot&re_mac=${mac}")

				if echo "$RESULT" | grep -q '"error"'; then
					echo "$RESULT"
				else
					echo '{"status":"ok"}'
				fi
				;;

			test_connection)
				get_config
				if [ -z "$MESH_PASS" ]; then
					echo '{"status":"error","message":"No password configured"}'
					exit 0
				fi
				# Clear old auth to force fresh login
				rm -f "$DATA_DIR/.auth_time" "$DATA_DIR/.token" "$DATA_DIR/cookies.txt"
				if asus_login; then
					TOKEN=$(cat "$DATA_DIR/.token" 2>/dev/null)
					RAW=$(curl -sk \
						-H "Cookie: asus_s_token=${TOKEN}" \
						-H "user-agent: asusrouter-Android-DUTUtil-1.0.0.245" \
						"${MESH_URL}/appGet.cgi?hook=nvram_get(productid)" 2>/dev/null)
					if echo "$RAW" | grep -q "productid"; then
						echo "{\"status\":\"ok\",\"data\":$RAW}"
					else
						echo '{"status":"error","message":"Logged in but could not read data. The router may have rate-limited login attempts. Wait 1-2 minutes and try again."}'
					fi
				else
					echo '{"status":"error","message":"Authentication failed — check username/password. If correct, wait 1-2 minutes (ASUS rate limits login attempts)."}'
				fi
				;;
		esac
		;;
esac
